-- What is the total revenue, operational costs, and gross profit of our company?

SELECT
        -- Calculate total revenue and operational costs
        (SELECT FORMAT(SUM(revenue), 'C', 'en-US') FROM dbo.loads) AS total_revenue, 
        (SELECT FORMAT(SUM(total_cost),'C', 'en-US') FROM dbo.fuel_purchases) AS total_fuel_cost,
        (SELECT FORMAT(SUM(total_cost), 'C', 'en-US') FROM dbo.maintenance_records) AS total_maintenance_cost,
        (SELECT FORMAT(SUM(claim_amount), 'C', 'en-US') FROM dbo.safety_incidents) AS total_incident_cost,
        
        -- Calculate total gross profit across all operational cost categories
        FORMAT((SELECT ROUND(SUM(revenue), 2) FROM dbo.loads) - 
        ((SELECT ROUND(SUM(total_cost), 2) FROM dbo.fuel_purchases) + 
        (SELECT ROUND(SUM(total_cost), 2) FROM dbo.maintenance_records) + 
        (SELECT ROUND(SUM(claim_amount), 2) FROM dbo.safety_incidents)), 'C', 'en-US') AS total_profit

